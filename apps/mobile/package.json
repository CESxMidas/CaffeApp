    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "@tanstack/react-query": "^5.74.4",
    "axios": "^1.8.4",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-font": "^14.0.12",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",

    "android:go": "expo start --android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas": "eas",
    "eas:build:preview:android": "eas build --platform android --profile preview",
    "eas:build:production:android": "eas build --platform android --profile production",
    "typegen": "expo customize tsconfig.json",
    "typecheck": "tsc --noEmit",
    "pretypecheck": "npm run typegen",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "echo \"No tests yet — Sprint 1+\""
  },
  "dependencies": {

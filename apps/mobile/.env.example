# =============================================================================
# CaffeApp Mobile — Environment variables
# Copy: cp .env.example .env
# Only EXPO_PUBLIC_* are exposed to the app bundle.
# =============================================================================

# --- API ---
EXPO_PUBLIC_API_URL=http://localhost:3000
# Android emulator: EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# EAS preview: set to staging API before build, e.g. https://staging-api.example.com
# EAS production: set to production API before build, e.g. https://api.example.com

# --- App ---
EXPO_PUBLIC_APP_ENV=development
# EAS preview uses staging; production uses production.

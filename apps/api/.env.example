# =============================================================================
# CaffeApp API — Environment variables
# Copy: cp .env.example .env
# =============================================================================

# --- Database ---
# Local PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/caffeapp?schema=public
# Neon (cloud) PostgreSQL — dùng chung 2 máy:
# DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.aws.neon.tech/CaffeApp?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.aws.neon.tech/CaffeApp?sslmode=require&channel_binding=require

# --- Integration tests (npm run test:integration) ---
# Dedicated test database. The name MUST contain "test" (guard refuses otherwise);
# integration tests never fall back to DATABASE_URL. Apply migrations first:
#   TEST_DATABASE_URL=... npm run db:migrate:deploy
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/caffeapp_test?schema=public

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Auth (JWT) ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://10.0.2.2:8081

# --- Email OTP (Gmail/App Password or SMTP provider) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM=your-gmail@gmail.com

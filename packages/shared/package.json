{
  "name": "@caffeapp/shared",
  "version": "1.0.0-mvp",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "react-native": "./src/contracts/index.ts",
      "default": "./dist/contracts/index.js"
    },
    "./domain": {
      "react-native": "./src/domain/session.types.ts",
      "default": "./dist/domain/session.types.js"
    },
    "./enums": {
      "react-native": "./src/enums/index.ts",
      "default": "./dist/enums/index.js"
    },
    "./types": {
      "react-native": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./dto": {
      "react-native": "./src/dto/index.ts",
      "default": "./dist/dto/index.js"
    },
    "./constants": {
      "react-native": "./src/constants/index.ts",
      "default": "./dist/constants/index.js"
    },
    "./theme": {
      "react-native": "./src/theme/tokens.ts",
      "default": "./dist/theme/tokens.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@caffeapp/tsconfig": "*",
    "typescript": "~6.0.3"
  }
}

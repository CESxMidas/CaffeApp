# Chuẩn hóa line ending: mọi text file dùng LF (khớp Prettier endOfLine: 'lf').
# Fix drift trên Windows khi core.autocrlf=true khiến format:check fail hàng loạt.
* text=auto eol=lf

# Binary — không normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.keystore binary
*.jks binary

# Windows scripts giữ CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

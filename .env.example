# =============================================================================
# CaffeApp — Root environment reference
# Copy app-specific files instead of using this directly:
#   cp apps/api/.env.example apps/api/.env
#   cp apps/mobile/.env.example apps/mobile/.env
# =============================================================================

# --- Mobile (Expo) — apps/mobile/.env ---
# EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_APP_ENV=development

# --- API (NestJS) — apps/api/.env ---
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/caffeapp?schema=public
# JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# PORT=3000
# NODE_ENV=development
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://10.0.2.2:8081

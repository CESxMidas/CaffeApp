{
  "name": "caffeapp",
  "version": "1.0.0-mvp",
  "private": true,
  "description": "CaffeApp — Cafe Management MVP",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@caffeapp/mobile",
    "mobile:tunnel": "npm run start:tunnel --workspace=@caffeapp/mobile",
    "mobile:android": "npm run android --workspace=@caffeapp/mobile",
    "mobile:android:go": "npm run android:go --workspace=@caffeapp/mobile",
    "mobile:eas:preview": "npm run eas:build:preview:android --workspace=@caffeapp/mobile",
    "mobile:eas:production": "npm run eas:build:production:android --workspace=@caffeapp/mobile",
    "mobile:ios": "npm run ios --workspace=@caffeapp/mobile",
    "api": "npm run start:dev --workspace=@caffeapp/api",
    "api:build": "npm run build --workspace=@caffeapp/api",
    "db:generate": "npm run db:generate --workspace=@caffeapp/api",
    "db:migrate": "npm run db:migrate --workspace=@caffeapp/api",
    "db:seed": "npm run db:seed --workspace=@caffeapp/api",
    "db:seed:staging": "npm run db:seed:staging --workspace=@caffeapp/api",
    "db:backup:pg": "node scripts/pg-backup.mjs",
    "phase3:verify-staging-data": "node scripts/verify-staging-data.mjs",
    "phase3:nfr": "node scripts/nfr-spot-check.mjs",
    "phase4:release-ready": "node scripts/verify-release-readiness.mjs",
    "phase8:smoke": "node scripts/go-live-smoke.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,json,md,yml,yaml}\"",
    "typecheck": "npm run build --workspace=@caffeapp/shared && npm run typecheck --workspaces --if-present",
    "test": "npm run build --workspace=@caffeapp/shared && npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspace=@caffeapp/api",
    "validate": "npm run format:check && npm run lint && npm run typecheck"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "expo-font": "14.0.12",
    "@expo/vector-icons": "^15.0.3",
    "@types/react": "~19.1.10"
  },
  "devDependencies": {
    "@caffeapp/eslint-config": "*",
    "@caffeapp/prettier-config": "*",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.26.1"
  }
}

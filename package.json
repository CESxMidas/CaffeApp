{
  "name": "caffeapp",
  "version": "1.0.0-mvp",
  "private": true,
  "description": "CaffeApp — Cafe Management MVP",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@caffeapp/mobile",
    "mobile:tunnel": "npm run start:tunnel --workspace=@caffeapp/mobile",
    "mobile:android": "npm run android --workspace=@caffeapp/mobile",
    "mobile:ios": "npm run ios --workspace=@caffeapp/mobile",
    "api": "npm run start:dev --workspace=@caffeapp/api",
    "api:build": "npm run build --workspace=@caffeapp/api",
    "db:generate": "npm run db:generate --workspace=@caffeapp/api",
    "db:migrate": "npm run db:migrate --workspace=@caffeapp/api",
    "db:seed": "npm run db:seed --workspace=@caffeapp/api",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,json,md,yml,yaml}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "validate": "npm run format:check && npm run lint && npm run typecheck"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@caffeapp/eslint-config": "*",
    "@caffeapp/prettier-config": "*",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.26.1"
  },
  "prettier": "@caffeapp/prettier-config"
}
